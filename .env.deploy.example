# ============================================================
# 漫创AI Web · 部署环境变量样例 (.env.deploy.example)
# ------------------------------------------------------------
# 复制为 .env.deploy 后填写。docker-compose 通过 env_file 注入 backend 容器。
# 不要把填好真实密钥的 .env.deploy 提交到 git（已被 .gitignore 覆盖 *.env）。
# ============================================================

# ---- 基本服务 ----
LIBAI_BACKEND_HOST=0.0.0.0
LIBAI_BACKEND_PORT=8765
LIBAI_APP_DATA_DIR=/app/data
LIBAI_BACKEND_LOG_LEVEL=info

# ---- CORS：填你的前端访问域名（同域反代可不填，跨域/独立域名必须填）----
# 多个用逗号分隔。例：https://your-domain.com,https://www.your-domain.com
LIBAI_CORS_ORIGINS=https://your-domain.com

# ============================================================
# 参考图存储（图生视频等功能需要把参考图变成上游可访问的公网 URL）
# 三选一，按需取消注释：
# ============================================================

# ---- 方案 A：VPS 本机自托管（推荐，不依赖外部图床）----
# 参考图存到 data/reference-media/，通过 <地址>/media/references/<文件名> 对外提供。
# 该地址必须是上游能访问到的公网地址，且能反代到后端 8765。
LIBAI_PUBLIC_BASE_URL=https://your-domain.com

# ---- 方案 B：S3 兼容 / 腾讯云 COS ----
# LIBAI_REFERENCE_STORAGE_PROVIDER=tencent-cos
# LIBAI_REFERENCE_STORAGE_S3_ENDPOINT=https://cos.<region>.myqcloud.com
# LIBAI_REFERENCE_STORAGE_PUBLIC_BASE_URL=https://<your-bucket>.cos.<region>.myqcloud.com
# LIBAI_REFERENCE_STORAGE_BUCKET=<your-bucket>
# LIBAI_REFERENCE_STORAGE_ACCESS_KEY=<your-access-key>
# LIBAI_REFERENCE_STORAGE_SECRET_KEY=<your-secret-key>
# LIBAI_REFERENCE_STORAGE_REGION=<your-region>
# LIBAI_REFERENCE_STORAGE_IMAGE_PREFIX=libai-reference-images

# ---- 方案 C：自定义图床（POST multipart 字段名 file，返回 JSON 含 url）----
# LIBAI_REFERENCE_IMAGE_UPLOAD_URL=https://your-image-host.example.com/api/upload

# ---- ffmpeg（镜像内已装，无需改）----
LIBAI_FFMPEG_PATH=/usr/bin/ffmpeg
LIBAI_FFPROBE_PATH=/usr/bin/ffprobe
