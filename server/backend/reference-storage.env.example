# ============================================================
# 漫创AI Web · 参考素材云存储配置模板 (reference-storage.env.example)
# ------------------------------------------------------------
# 用途：把"参考图/参考音频/参考视频"上传到对象存储(S3 兼容/腾讯云 COS)，
#       生成可被上游模型访问的公网 URL。不配置则该上传功能不可用，
#       但画布主流程(项目、节点、生成任务)不受影响。
#
# 使用方法：
#   1. 复制本文件为同目录下的  reference-storage.env
#   2. 填入你自己的存储桶与密钥
#   3. server/run.py 会在存在该文件时自动加载(见下方说明)
#
# 安全提示：reference-storage.env 已被 .gitignore 排除，切勿提交真实密钥。
# ============================================================

# ---- 主存储 (S3 兼容 / 腾讯云 COS 示例) ----
LIBAI_REFERENCE_STORAGE_PROVIDER=tencent-cos
LIBAI_REFERENCE_STORAGE_S3_ENDPOINT=https://cos.<region>.myqcloud.com
LIBAI_REFERENCE_STORAGE_PUBLIC_BASE_URL=https://<your-bucket>.cos.<region>.myqcloud.com
LIBAI_REFERENCE_STORAGE_BUCKET=<your-bucket>
LIBAI_REFERENCE_STORAGE_ACCESS_KEY=<your-access-key>
LIBAI_REFERENCE_STORAGE_SECRET_KEY=<your-secret-key>
LIBAI_REFERENCE_STORAGE_REGION=<your-region>
LIBAI_REFERENCE_STORAGE_IMAGE_PREFIX=libai-reference-images
LIBAI_REFERENCE_STORAGE_AUDIO_PREFIX=libai-reference-audios
LIBAI_REFERENCE_STORAGE_VIDEO_PREFIX=libai-reference-videos

# ---- 备用存储 (可选；仅当上面主存储未配置时启用) ----
# LIBAI_REFERENCE_IMAGE_S3_ENDPOINT=https://<s3-endpoint>
# LIBAI_REFERENCE_IMAGE_S3_BUCKET=<your-bucket>
# LIBAI_REFERENCE_IMAGE_S3_ACCESS_KEY=<your-access-key>
# LIBAI_REFERENCE_IMAGE_S3_SECRET_KEY=<your-secret-key>
# LIBAI_REFERENCE_IMAGE_S3_REGION=us-east-1
# LIBAI_REFERENCE_IMAGE_S3_PREFIX=libai-reference-images
# LIBAI_REFERENCE_AUDIO_S3_PREFIX=libai-reference-audios
# LIBAI_REFERENCE_VIDEO_S3_PREFIX=libai-reference-videos

# ---- 图片压缩阈值 (可选) ----
LIBAI_REFERENCE_IMAGE_COMPRESS_THRESHOLD_BYTES=2097152
LIBAI_REFERENCE_IMAGE_COMPRESS_TARGET_BYTES=2097152
LIBAI_REFERENCE_IMAGE_HOSTING_CONCURRENCY=5
